generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MergeJob {
  id         String   @id @default(cuid())
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  outputPath String?
}
