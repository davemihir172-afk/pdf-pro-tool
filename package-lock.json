{
  "name": "pro-pdf-mate-monorepo",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "pro-pdf-mate-monorepo",
      "version": "1.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=18.18.0"
      }
    },
    "apps/api": {
      "name": "@propdfmate/api",
      "version": "1.0.0",
      "dependencies": {
        "@propdfmate/ai-tools": "1.0.0",
        "@propdfmate/queue": "1.0.0",
        "@propdfmate/storage": "1.0.0"
      }
    },
    "apps/web": {
      "name": "@propdfmate/web",
      "version": "1.0.0"
    },
    "apps/worker": {
      "name": "@propdfmate/worker",
      "version": "1.0.0",
      "dependencies": {
        "@propdfmate/pdf-engine": "1.0.0",
        "@propdfmate/queue": "1.0.0",
        "@propdfmate/storage": "1.0.0"
      }
    },
    "node_modules/@propdfmate/ai-tools": {
      "resolved": "packages/ai-tools",
      "link": true
    },
    "node_modules/@propdfmate/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@propdfmate/pdf-engine": {
      "resolved": "packages/pdf-engine",
      "link": true
    },
    "node_modules/@propdfmate/queue": {
      "resolved": "packages/queue",
      "link": true
    },
    "node_modules/@propdfmate/storage": {
      "resolved": "packages/storage",
      "link": true
    },
    "node_modules/@propdfmate/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "node_modules/@propdfmate/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/@propdfmate/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "packages/ai-tools": {
      "name": "@propdfmate/ai-tools",
      "version": "1.0.0"
    },
    "packages/pdf-engine": {
      "name": "@propdfmate/pdf-engine",
      "version": "1.0.0"
    },
    "packages/queue": {
      "name": "@propdfmate/queue",
      "version": "1.0.0"
    },
    "packages/storage": {
      "name": "@propdfmate/storage",
      "version": "1.0.0"
    },
    "packages/ui": {
      "name": "@propdfmate/ui",
      "version": "1.0.0"
    }
  }
}
