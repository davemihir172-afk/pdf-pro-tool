{
  "name": "propdfmate",
  "version": "1.0.0",
  "description": "Pro PDF Mate - scalable Node.js + Express foundation for online PDF tools",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "build:css": "tailwindcss -i ./public/css/tailwind.input.css -o ./public/css/styles.css --minify",
    "dev:css": "tailwindcss -i ./public/css/tailwind.input.css -o ./public/css/styles.css --watch",
    "start": "node server.js",
    "start:full": "npm run build:css && node server.js"
  },
  "keywords": [
    "pdf",
    "express",
    "tailwind",
    "multer",
    "pdf-lib"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69",
    "puppeteer": "^23.7.0",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.15"
  }
}
